# macOS
.DS_Store
.AppleDouble
.LSOverride
*.rtfd

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
venv/

# Secrets / credentials
config.json
*.env
.env

# Database (large, local only)
guardian.db
*.sqbpro

# LLM knowledge (backed up separately as knowledge_backup.json).
# Runtime knowledge.json is mutable site-state — never tracked.
# EXCEPTION (P-029 knowledge — D-29, 2026-05-08): the baseline seed
# shipped in the installer payload at
# installer/macos-pkg/resources/knowledge/knowledge.json IS tracked, so
# every .pkg builds against a known-good 96-profile baseline. Do not
# remove this exception without coordinating with build_pkg.sh step 4l
# and tests/installer/test_p029_knowledge_json_installer.sh.
knowledge.json
!installer/macos-pkg/resources/knowledge/knowledge.json
master_knowledge.json

# Logs
*.log
logs/

# AMS API spec (large, not needed in repo)
ams_api_spec.json

# LaunchAgent plist (machine-specific)
com.bixbit.mining-guardian.plist

# AI Toolkit
.claude/.toolkit-manifest.json
.claude/.toolkit-version
.claude/checkpoints/
.claude/state/
.claude/.backups/
.claude/settings.local.json
.claude/config.local.json
.claude/command-history.log
.claude/tui/node_modules/
.claude/tui/dist/
.claude/visual/current/
.claude/visual/diffs/
.claude/pyramid/
.ai/

# WIP directories (resume-safety checkpoints, regenerated as needed)
*_wip/

# SQLite WAL files (runtime only)
guardian.db-shm
guardian.db-wal

# Backup files (use git history instead)
*.bak.*
*.backup
*.backup_*
*.backup-*

# Backups directory (local only)
backups/
deploy/*_LIVE.json
# Split databases - too large for GitHub
databases/*.db
databases/*.db-shm
databases/*.db-wal

# Subagent / editor artifacts (not part of the project)
.claude/
.mcp.json

# Intelligence catalog JSON backup dumps (local only)
intelligence-catalog/data/*.bak_*

# Generated reports (local outputs, regenerated on demand)
reports/
.env.backup*
