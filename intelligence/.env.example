# ============================================================================
# Miner Intelligence Catalog — environment file
# ============================================================================
# Copy this file to .env and fill in the values. NEVER commit .env to git.
# The .env file lives only on ROBS-PC at:
#   D:\miner-intelligence\.env
# ============================================================================

# Postgres password — generate a strong random one. Do NOT reuse a password
# from any other system. Suggested generation:
#   openssl rand -base64 32
# Or in PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_FIRST_RUN

# Backup encryption passphrase — used when nightly pg_dump output is encrypted
# before being pushed to cloud backup (Backblaze B2 / S3). Different from
# the postgres password. Store the recovery copy somewhere safe.
BACKUP_ENCRYPTION_KEY=CHANGE_ME_BEFORE_FIRST_BACKUP

# Cloud backup credentials (filled in when we set up Backblaze B2 or S3)
# B2_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET_NAME=mining-guardian-intelligence-backups
