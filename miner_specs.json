{
  "_comment": "Published stock hashrate specs for Mining Guardian — Tier 2 evaluation. Sources: MicroBT official shop, Bitmain support, Canaan official, Bitdeer official, hashrateindex.com. All values are manufacturer-rated at stock firmware. Actual values fluctuate ±3% (hashrate) and ±5% (power). Last updated: 2026-03-31.",

  "_evaluation_tiers": {
    "tier_1": "BiXBiT firmware — compare against currentProfile parsed TH/s (live from AMS miner_config endpoint). Most accurate.",
    "tier_2": "Stock/Auradine/other firmware with known model — compare against default_rated_ths from this file.",
    "tier_3": "Unknown model or model not in this file — use 3-5 day running average baseline (miner_baselines table in guardian.db)."
  },

  "_profile_parsing_rules": {
    "bixbit_antminer":    "Parse '{TH/s} TH/s - ~{W} W' — strip ~ before parsing watts. First number = TH/s.",
    "bixbit_s21exphyd":   "Same format. profileName is 'freq:voltage:voltage' internal key.",
    "auradine_ah3880":    "Mode-based: turbo=600, normal~500, eco=variable. Use profile_map in this file.",
    "stock_antminer":     "Use default_rated_ths. No profile data available from AMS.",
    "whatsminer":         "Power modes: Low/Normal/High. Use normal mode as default_rated_ths.",
    "avalon":             "Three modes: Normal, High Performance, Low Power. Use Normal as default_rated_ths."
  },

