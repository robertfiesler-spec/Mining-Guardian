# Catalog API environment template.
# Copy to .env at install time and replace placeholders with real values.
# .env files MUST NOT be committed to git (see .gitignore).

# API key used by clients calling this service. Generate with:
#   openssl rand -hex 32
CATALOG_API_KEY=__GENERATE_AT_INSTALL_TIME__

DB_HOST=mining-guardian-db
DB_PORT=5432
DB_NAME=mining_guardian
DB_USER=guardian_admin
# Set DB_PASSWORD to the value provisioned by the installer.
# Do NOT commit a real password here.
DB_PASSWORD=__SET_BY_INSTALLER__

API_HOST=0.0.0.0
API_PORT=8420
