# Catalog API environment template.
# Copy to .env at install time and replace placeholders with real values.
# .env files MUST NOT be committed to git (see .gitignore).

# API key used by clients calling this service. Generate with:
#   openssl rand -hex 32
CATALOG_API_KEY=__GENERATE_AT_INSTALL_TIME__

# P-018E: the catalog API now resolves DB connection params via
# core.db_targets.catalog_target() (canonical GUARDIAN_PG_* family).
# These legacy DB_* keys still take precedence when set explicitly,
# but new deployments should leave them empty and rely on the
# GUARDIAN_PG_HOST/_PORT/_USER/_PASSWORD/_CATALOG_DBNAME env vars
# the customer Mac mini's installer already writes.
#
# If you DO override here, set DB_NAME to mining_guardian_catalog (the
# CATALOG database), NOT mining_guardian (the operational DB). The
# pre-P-018E default of `mining_guardian` was a long-standing latent
# bug — the catalog API would have served from the operational DB.
DB_HOST=
DB_PORT=
DB_NAME=mining_guardian_catalog
DB_USER=
# Set DB_PASSWORD to the value provisioned by the installer, OR leave
# empty to fall back to GUARDIAN_PG_PASSWORD / MG_DB_PASSWORD via
# core.db_targets. Do NOT commit a real password here.
DB_PASSWORD=

# CRIT-6: bind loopback only by default. Override to 0.0.0.0 ONLY when the
# container is fronted by an authenticated reverse proxy + TLS. Direct LAN
# exposure is not supported — there are no rate limits beyond the per-IP
# slowapi defaults below, and the API key is the only auth boundary.
API_HOST=127.0.0.1
API_PORT=8420

# CRIT-6: rate limits. Format: "<n>/<period>" where period is second/minute/hour.
# Defaults are sized for a single Mac Mini serving ≤ a few hundred miners.
CATALOG_RATE_LIMIT_SCAN_BUNDLE=60/minute
CATALOG_RATE_LIMIT_MINER=120/minute
CATALOG_RATE_LIMIT_HEALTH=600/minute
