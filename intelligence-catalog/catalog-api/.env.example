# Catalog API environment template.
# Copy to .env at install time and replace placeholders with real values.
# .env files MUST NOT be committed to git (see .gitignore).

# API key used by clients calling this service. Generate with:
#   openssl rand -hex 32
CATALOG_API_KEY=__GENERATE_AT_INSTALL_TIME__

DB_HOST=mining-guardian-db
DB_PORT=5432
DB_NAME=mining_guardian
DB_USER=guardian_admin
# Set DB_PASSWORD to the value provisioned by the installer.
# Do NOT commit a real password here.
DB_PASSWORD=__SET_BY_INSTALLER__

# CRIT-6: bind loopback only by default. Override to 0.0.0.0 ONLY when the
# container is fronted by an authenticated reverse proxy + TLS. Direct LAN
# exposure is not supported — there are no rate limits beyond the per-IP
# slowapi defaults below, and the API key is the only auth boundary.
API_HOST=127.0.0.1
API_PORT=8420

# CRIT-6: rate limits. Format: "<n>/<period>" where period is second/minute/hour.
# Defaults are sized for a single Mac Mini serving ≤ a few hundred miners.
CATALOG_RATE_LIMIT_SCAN_BUNDLE=60/minute
CATALOG_RATE_LIMIT_MINER=120/minute
CATALOG_RATE_LIMIT_HEALTH=600/minute
