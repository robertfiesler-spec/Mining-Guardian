# Mining Guardian — Complete Environment Variable Reference
# Copy to .env and fill in your values. .env is gitignored and never committed.
# Last updated: 2026-04-14

# ═══════════════════════════════════════════════════════════════
# AMS (BiXBiT Mining Management)
# ═══════════════════════════════════════════════════════════════
AMS_EMAIL=your@email.com
AMS_PASSWORD=yourpassword

# Workspace ID — numeric integer found in the AMS UI URL
# e.g. https://staging-ui.dev.bixbit.io/workspace/42  → use 42
AMS_WORKSPACE_ID=1

# Workspace API key — UUID shown in Workspace > General settings page
# Used as fallback auth if workspace ID selection fails
AMS_API_KEY=your-uuid-api-key-here

# ═══════════════════════════════════════════════════════════════
# LLM / Ollama — local Qwen 32B for hourly scans + daily deep dives
# ═══════════════════════════════════════════════════════════════
OLLAMA_URL=http://100.110.87.1:11434
OLLAMA_MODEL=qwen2.5:32b-instruct-q4_K_M

# ═══════════════════════════════════════════════════════════════
# Claude (Anthropic) — weekly deep analysis + Slack Q&A
# ═══════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ═══════════════════════════════════════════════════════════════
# Intelligence Catalog — fleet knowledge API
# ═══════════════════════════════════════════════════════════════
CATALOG_API_URL=http://100.110.87.1:8420
CATALOG_API_KEY=your-catalog-api-key-here

# ═══════════════════════════════════════════════════════════════
# Slack — bot token, signing secret, app token, authorized users
# ═══════════════════════════════════════════════════════════════
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-your-slack-app-token

# Comma-separated Slack user IDs authorized to run commands and approve actions
AUTHORIZED_SLACK_USER_IDS=U12345,U67890

# ═══════════════════════════════════════════════════════════════
# Slack Channels — override default channel names
# Used by MiningGuardian.SlackNotifier for routing messages
# ═══════════════════════════════════════════════════════════════
MG_CHANNEL_MAIN=mining-guardian
MG_CHANNEL_SCANS=mg-scans
MG_CHANNEL_LOGS=mg-logs
MG_CHANNEL_AI=mg-ai-reports
MG_CHANNEL_ALERTS=mg-alerts
MG_CHANNEL_APPROVALS=mg-approvals

# ═══════════════════════════════════════════════════════════════
# Hardware Credentials — PDU, Auradine miners, Eclypse HVAC
# ═══════════════════════════════════════════════════════════════

# PDU (facility power distribution units)
PDU_USERNAME=admin
PDU_PASSWORD=your-pdu-password

# Auradine Teraflux miners — SSH/API credentials
AURADINE_USER=admin
AURADINE_PASS=your-auradine-password

# Eclypse HVAC controllers (warehouse + S19J Pro container)
ECLYPSE_USER=admin
ECLYPSE_PASS=your-eclypse-password

# AV-2 Plant HVAC (Big Star BlockChain — S19J Pro container)
AV2_PLANT_USER=your-av2-username
AV2_PLANT_PASSWORD=your-av2-password

# ═══════════════════════════════════════════════════════════════
# Internal API — authentication between Mining Guardian services
# ═══════════════════════════════════════════════════════════════
INTERNAL_API_SECRET=your-internal-api-secret
DASHBOARD_URL=http://localhost:8585

# ═══════════════════════════════════════════════════════════════
# Guardian Config — path to config.json (default: config.json in repo root)
# ═══════════════════════════════════════════════════════════════
# GUARDIAN_CONFIG=config.json

# ═══════════════════════════════════════════════════════════════
# Intelligence Catalog PostgreSQL Database
# Used by intelligence-catalog/catalog-api/catalog_api.py
# ═══════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mining_guardian
DB_USER=guardian_admin
DB_PASSWORD=your-db-password-here
API_HOST=0.0.0.0
API_PORT=8420

# OpenClaw integration was removed in Bucket 4 (2026-04-29). The previous
# OPENCLAW_TOKEN / OPENCLAW_WEBHOOK_URL block lived here — any old .env that
# still defines these can safely drop them; nothing reads them anymore.
