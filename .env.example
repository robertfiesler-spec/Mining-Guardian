# Mining Guardian — Complete Environment Variable Reference
# Copy to .env and fill in your values. .env is gitignored and never committed.
# Last updated: 2026-04-14

# ═══════════════════════════════════════════════════════════════
# AMS (BiXBiT Mining Management)
# ═══════════════════════════════════════════════════════════════
AMS_EMAIL=your@email.com
AMS_PASSWORD=yourpassword

# Workspace ID — numeric integer found in the AMS UI URL
# e.g. https://staging-ui.dev.bixbit.io/workspace/42  → use 42
AMS_WORKSPACE_ID=1

# Workspace API key — UUID shown in Workspace > General settings page
# Used as fallback auth if workspace ID selection fails
AMS_API_KEY=your-uuid-api-key-here

# ═══════════════════════════════════════════════════════════════
# LLM / Ollama — local Mac Mini Ollama (D-9 / S-13 / P-018E)
# OLLAMA_HOST is the base URL the launcher exports; OLLAMA_URL adds the
# /api/generate suffix some legacy code paths still read.
# ═══════════════════════════════════════════════════════════════
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen2.5:32b-instruct-q4_K_M

# ═══════════════════════════════════════════════════════════════
# Claude (Anthropic) — weekly deep analysis + Slack Q&A
# ═══════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ═══════════════════════════════════════════════════════════════
# Intelligence Catalog — fleet knowledge API
#
# P-018C/D/E (2026-05-06): the Mini reads the catalog DB directly via
# core.db_targets.catalog_target() — there is NO local HTTP catalog
# service. CATALOG_API_URL/KEY are kept for the optional, opt-in
# rollback path (`MG_CATALOG_HTTP_FALLBACK_URL` in
# ai/catalog_context.py); the runtime ignores `CATALOG_API_URL` by
# design. Leave both keys empty unless an operator explicitly stands
# up an out-of-Mini catalog API. NEVER set CATALOG_API_URL to the
# retired ROBS-PC tailscale host (100.110.87.1:8420) — the runtime
# will refuse it.
# ═══════════════════════════════════════════════════════════════
CATALOG_API_URL=
CATALOG_API_KEY=

# ═══════════════════════════════════════════════════════════════
# Slack — bot token, signing secret, app token, authorized users
# ═══════════════════════════════════════════════════════════════
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-your-slack-app-token

# Comma-separated Slack user IDs authorized to run commands and approve actions
AUTHORIZED_SLACK_USER_IDS=U12345,U67890

# ═══════════════════════════════════════════════════════════════
# Slack Channels — override default channel names
# Used by MiningGuardian.SlackNotifier for routing messages
# ═══════════════════════════════════════════════════════════════
MG_CHANNEL_MAIN=mining-guardian
MG_CHANNEL_SCANS=mg-scans
MG_CHANNEL_LOGS=mg-logs
MG_CHANNEL_AI=mg-ai-reports
MG_CHANNEL_ALERTS=mg-alerts
MG_CHANNEL_APPROVALS=mg-approvals

# ═══════════════════════════════════════════════════════════════
# Hardware Credentials — PDU, Auradine miners, Eclypse HVAC
# ═══════════════════════════════════════════════════════════════

# PDU (facility power distribution units)
PDU_USERNAME=admin
PDU_PASSWORD=your-pdu-password

# Auradine Teraflux miners — SSH/API credentials
AURADINE_USER=admin
AURADINE_PASS=your-auradine-password

# Eclypse HVAC controllers (warehouse + S19J Pro container)
ECLYPSE_USER=admin
ECLYPSE_PASS=your-eclypse-password

# AV-2 Plant HVAC (Big Star BlockChain — S19J Pro container)
AV2_PLANT_USER=your-av2-username
AV2_PLANT_PASSWORD=your-av2-password

# ═══════════════════════════════════════════════════════════════
# Internal API — authentication between Mining Guardian services
# ═══════════════════════════════════════════════════════════════
INTERNAL_API_SECRET=your-internal-api-secret
DASHBOARD_URL=http://localhost:8585

# ═══════════════════════════════════════════════════════════════
# Dashboard API bind config (W25, 2026-05-13)
#
# dashboard_api.py listens on $MG_DASHBOARD_HOST:$MG_DASHBOARD_PORT.
#
#   - Default (when these vars are unset): 127.0.0.1:8585. Safe for
#     developer laptops — the process is only reachable from the
#     same machine.
#
#   - Production Mac Mini: set MG_DASHBOARD_HOST=0.0.0.0 so the
#     embedded HTML pages dashboard_api serves (/ai/dashboard,
#     /mhs, /fleet/board_stats, /api/report/*) are reachable from
#     Grafana's iframes over the Tailscale subnet at
#     http://<tailscale-ip>:8585. The Mini has no public NIC, so
#     0.0.0.0 here means "loopback + Tailscale" — both inside the
#     operator's trust boundary.
#
# DO NOT set MG_DASHBOARD_HOST=0.0.0.0 on a host with a public NIC.
# dashboard_api currently has no authentication on its endpoints
# (rate limiting only). For public-facing deployments, leave it
# loopback and front it with an authenticating reverse proxy
# (nginx + basic auth, Cloudflare tunnel with auth header, etc.).
# See `intelligence-catalog/catalog-api/catalog_api.py` for the
# CRIT-6 hardened reference implementation if you need to expose
# this service across an untrusted network.
# ═══════════════════════════════════════════════════════════════
MG_DASHBOARD_HOST=127.0.0.1
MG_DASHBOARD_PORT=8585

# ═══════════════════════════════════════════════════════════════
# Guardian Config — path to config.json (default: config.json in repo root)
# ═══════════════════════════════════════════════════════════════
# GUARDIAN_CONFIG=config.json

# ═══════════════════════════════════════════════════════════════
# Operational + Catalog PostgreSQL Databases (canonical names)
#
# Mining Guardian runs TWO separate Postgres instances on the Mini
# (W14, landed 2026-05-13):
#
#   - Operational DB `mining_guardian` on $GUARDIAN_PG_HOST:$GUARDIAN_PG_PORT
#     (default 127.0.0.1:5432), container `mining-guardian-db`.
#     Holds scan/audit/AI tables.
#
#   - Catalog DB `mining_guardian_catalog` on
#     $GUARDIAN_PG_CATALOG_HOST:$GUARDIAN_PG_CATALOG_PORT (default
#     127.0.0.1:5433), container `mg-catalog-db`. Holds the seeded
#     Mining Intelligence Catalog (hardware.miner_models, manufacturers,
#     staging.miner_model_proposals, market.war_stories, …).
#
# Same user/password for both instances (D2, locked 2026-05-12).
#
# Python code MUST go through core.db_targets — do NOT read these vars
# directly outside core/db_targets.py itself. The cohort guard test
# tests/test_w14a_no_direct_pg_env_reads.py fails CI on direct reads.
#
# When the CATALOG_HOST/PORT vars are unset, catalog_target() falls back
# to the operational host/port — this preserves pre-W14 behavior for
# fresh installs that haven't completed the two-container provisioning
# yet, and makes W14 rollback config-only (remove the two vars and
# catalog reads return to port 5432).
#
# See docs/strategy/W14_PREP.md (topology), docs/strategy/AMENDMENTS_2026-05-12.md
# §A01 (rationale), docs/strategy/W14_POSTMORTEM_2026-05-13.md
# (what goes wrong when conventions are bypassed).
# ═══════════════════════════════════════════════════════════════
GUARDIAN_PG_HOST=127.0.0.1
GUARDIAN_PG_PORT=5432
GUARDIAN_PG_USER=mg
GUARDIAN_PG_PASSWORD=your-db-password-here
GUARDIAN_PG_DBNAME=mining_guardian
GUARDIAN_PG_CATALOG_DBNAME=mining_guardian_catalog

# W14 (2026-05-13) — catalog DB on a separate Postgres instance.
# Leave these unset to route catalog reads to the operational host/port
# (pre-W14 fallback). Set to 127.0.0.1:5433 after running the W14
# two-container provisioning step in install_colima.sh.
GUARDIAN_PG_CATALOG_HOST=127.0.0.1
GUARDIAN_PG_CATALOG_PORT=5433

# IMPORTANT — quote handling. Do NOT wrap secret values in single or
# double quotes in this file. Python's os.environ reading and the
# `export $(grep ... | xargs)` pattern in the launchctl wrappers both
# strip surrounding quotes; shell-direct readers (cut -d= -f2-) do not.
# A quoted value in .env produced the W14 Step 2 password bug — see
# docs/strategy/W14_POSTMORTEM_2026-05-13.md §2.

# `MG_DB_PASSWORD` is the older name still read by mg_import_tool and
# intelligence-catalog/db/dual_writer.py. The installer writes both with
# the same value; setting just GUARDIAN_PG_PASSWORD is also fine because
# core/db_targets.py falls back to MG_DB_PASSWORD when the former is
# unset.
MG_DB_PASSWORD=your-db-password-here

# ═══════════════════════════════════════════════════════════════
# Intelligence Catalog API server (legacy DB_* family)
# Used by intelligence-catalog/catalog-api/catalog_api.py only.
# Do NOT introduce new readers of these — use core/db_targets.py.
# ═══════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mining_guardian
DB_USER=guardian_admin
DB_PASSWORD=your-db-password-here
API_HOST=0.0.0.0
API_PORT=8420

# OpenClaw integration was removed in Bucket 4 (2026-04-29). The previous
# OPENCLAW_TOKEN / OPENCLAW_WEBHOOK_URL block lived here — any old .env that
# still defines these can safely drop them; nothing reads them anymore.
