# BiXBiT AMS credentials — copy this file to .env and fill in your values
# .env is gitignored and never committed to source control

AMS_EMAIL=your@email.com
AMS_PASSWORD=yourpassword

# Workspace ID — numeric integer found in the AMS UI URL
# e.g. https://staging-ui.dev.bixbit.io/workspace/42  → use 42
AMS_WORKSPACE_ID=1

# Workspace API key — UUID shown in Workspace > General settings page
# Used as fallback auth if workspace ID selection fails
AMS_API_KEY=your-uuid-api-key-here
