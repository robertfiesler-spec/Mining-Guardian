<?xml version="1.0" encoding="UTF-8"?>
<!--
  com.miningguardian.intelligence-report.plist (Bucket 6 / installer rebuild)

  launchd LaunchDaemon for the Intelligence Report API on macOS.
  Mirrors the systemd unit `intelligence-report.service`
  (deploy/intelligence-report.service) running today on the VPS.

  Service entry point: api/intelligence_report_api.py
  Restart policy:      always restart on crash, 5s throttle (matches systemd RestartSec=5).

  Bind/port hardening (S-8): the API binds to 127.0.0.1 by default, with
  CORS controlled via INTELLIGENCE_REPORT_CORS_ALLOW in .env (PR #66).
  This plist does not need to do anything special — the application reads
  .env and does the right thing.

  GUARDIAN_DB note: the systemd unit sets GUARDIAN_DB=/root/Mining-Guardian/guardian.db,
  but on macOS the install root is /Library/Application Support/MiningGuardian, so we set
  GUARDIAN_DB=/Library/Application Support/MiningGuardian/guardian.db here. The launcher wrapper
  also sources .env, which can override this if the operator wants a custom
  path.

  Install path: copied by postinstall.sh to
      /Library/LaunchDaemons/com.miningguardian.intelligence-report.plist
  and loaded with:
      sudo launchctl bootstrap system <path-to-plist>

  Path + env conventions (match scanner / dashboard-api / approval-api / feedback-loop):
    install root              /Library/Application Support/MiningGuardian
    .env (private secrets)    /Library/Application Support/MiningGuardian/.env  (mode 0600)
    venv                      /Library/Application Support/MiningGuardian/venv
    launcher wrapper          /Library/Application Support/MiningGuardian/bin/intelligence_report_launcher.sh
    logs                      /Library/Application Support/MiningGuardian/logs/
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.miningguardian.intelligence-report</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Library/Application Support/MiningGuardian/bin/intelligence_report_launcher.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Library/Application Support/MiningGuardian</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>/Library/Application Support/MiningGuardian/logs/intelligence-report.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Library/Application Support/MiningGuardian/logs/intelligence-report.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
        <key>PATH</key>
        <string>/Library/Application Support/MiningGuardian/venv/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>GUARDIAN_DB</key>
        <string>/Library/Application Support/MiningGuardian/guardian.db</string>
    </dict>
</dict>
</plist>
