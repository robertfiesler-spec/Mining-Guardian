      "id": 13,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "<style>\n.conf-table{width:100%;border-collapse:collapse;font-size:13px}\n.conf-table th{text-align:left;padding:8px;border-bottom:2px solid #334155;color:#94a3b8}\n.conf-table td{padding:6px 8px;border-bottom:1px solid #1e293b}\n.conf-badge{padding:4px 10px;border-radius:4px;font-weight:bold;font-size:14px;display:inline-block;min-width:45px;text-align:center}\n.conf-high{background:#166534;color:#4ade80;border:1px solid #22c55e}\n.conf-med{background:#854d0e;color:#fde047;border:1px solid #eab308}\n.conf-low{background:#991b1b;color:#fca5a5;border:1px solid #ef4444}\n.type-tag{font-size:10px;padding:2px 6px;border-radius:3px;font-weight:bold}\n.type-PREDICTION{background:#3b82f6;color:white}\n.type-INSIGHT{background:#8b5cf6;color:white}\n.type-ANALYSIS{background:#06b6d4;color:white}\n.summary-box{display:flex;gap:16px;margin-bottom:16px;flex-wrap:wrap}\n.summary-item{background:#1e293b;padding:12px 20px;border-radius:8px;text-align:center;border:1px solid #334155}\n.summary-value{font-size:28px;font-weight:bold}\n.summary-label{font-size:11px;color:#94a3b8;margin-top:4px}\n.high{color:#4ade80}.med{color:#fde047}.low{color:#f87171}\n#status{color:#64748b;font-size:11px;margin-top:8px}\n</style>\n<div id=\"summary\" class=\"summary-box\"></div>\n<table class=\"conf-table\">\n<thead><tr><th>Time</th><th>Type</th><th>IP</th><th>Model</th><th>Statement</th><th style=\"text-align:center\">Confidence</th></tr></thead>\n<tbody id=\"tbody\"></tbody>\n</table>\n<div id=\"status\">Loading...</div>\n<script>\nasync function loadAnalyses(){\n  try{\n    const r=await fetch('http://100.69.66.32:8585/ai/recent_analyses?hours=6');\n    const d=await r.json();\n    if(d.error){document.getElementById('status').textContent='Error: '+d.error;return}\n    const s=d.summary;\n    const avgClass=s.avg_confidence_pct>=80?'high':s.avg_confidence_pct>=50?'med':'low';\n    document.getElementById('summary').innerHTML=\n      '<div class=\"summary-item\"><div class=\"summary-value '+avgClass+'\">'+s.avg_confidence_pct.toFixed(0)+'%</div><div class=\"summary-label\">Avg Confidence</div></div>'+\n      '<div class=\"summary-item\"><div class=\"summary-value\">'+s.total_analyses+'</div><div class=\"summary-label\">Total Analyses</div></div>'+\n      '<div class=\"summary-item\"><div class=\"summary-value high\">'+s.high_confidence+'</div><div class=\"summary-label\">High (80%+)</div></div>'+\n      '<div class=\"summary-item\"><div class=\"summary-value med\">'+s.medium_confidence+'</div><div class=\"summary-label\">Medium</div></div>'+\n      '<div class=\"summary-item\"><div class=\"summary-value low\">'+(s.low_confidence||0)+'</div><div class=\"summary-label\">Low (&lt;50%)</div></div>';\n    const tbody=document.getElementById('tbody');\n    tbody.innerHTML='';\n    d.analyses.slice(0,25).forEach(a=>{\n      const ts=new Date(a.timestamp).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});\n      const confClass=a.confidence_pct>=80?'conf-high':a.confidence_pct>=50?'conf-med':'conf-low';\n      const stmt=(a.statement||'').substring(0,80)+(a.statement&&a.statement.length>80?'...':'');\n      tbody.innerHTML+=\n        '<tr><td style=\"white-space:nowrap;color:#94a3b8\">'+ts+'</td>'+\n        '<td><span class=\"type-tag type-'+a.type+'\">'+a.type+'</span></td>'+\n        '<td style=\"font-family:monospace;font-size:12px;color:#60a5fa\">'+a.miner_ip+'</td>'+\n        '<td style=\"color:#94a3b8\">'+(a.model||'')+'</td>'+\n        '<td style=\"max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#e2e8f0\">'+stmt+'</td>'+\n        '<td style=\"text-align:center\"><span class=\"conf-badge '+confClass+'\">'+a.confidence_pct+'%</span></td></tr>';\n    });\n    document.getElementById('status').textContent='Updated: '+new Date().toLocaleTimeString()+' | '+d.analyses.length+' analyses';\n  }catch(e){document.getElementById('status').textContent='Error: '+e.message}\n}\nloadAnalyses();\nsetInterval(loadAnalyses,60000);\n</script>",
        "mode": "html"
      },
      "pluginVersion": "10.4.1",
      "title": "\ud83c\udfaf Recent AI Analyses (Last 6 Hours)",
      "type": "text"
    },
