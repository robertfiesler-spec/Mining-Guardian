      "options": {
        "content": "<div id=\"mg-status\" style=\"font-family:-apple-system,sans-serif;font-size:12px;color:#ddd;padding:4px\">Loading...</div><script>(function(){var ip='$miner';fetch('http://100.69.66.32:8585/miner/status/'+ip).then(r=>r.json()).then(d=>{var el=document.getElementById('mg-status');var c=d.current||{};var statusColor=c.issue?'#e74c3c':'#2ecc71';var actionColors={RESTART:'#e67e22',PDU_CYCLE:'#e74c3c',MONITOR:'#f39c12',RESTART_CHECK_BOARDS:'#c0392b',PHYSICAL_CYCLE:'#8e44ad'};var html='<div style=\"display:flex;gap:16px;flex-wrap:wrap;margin-bottom:10px\">';html+='<div><span style=\"color:#888\">Status</span> <span style=\"background:'+statusColor+';color:#fff;padding:2px 8px;border-radius:4px;font-weight:600\">'+(c.status||'?').toUpperCase()+'</span></div>';if(c.action){html+='<div><span style=\"background:'+(actionColors[c.action]||'#666')+';color:#fff;padding:2px 8px;border-radius:4px;font-weight:600\">'+c.action+'</span></div>';}html+='<div><span style=\"color:#888\">Model</span> '+(c.model||'\u2014')+'</div>';html+='<div><span style=\"color:#888\">HR</span> '+(c.hashrate_pct||'?')+'%</div>';html+='<div><span style=\"color:#888\">Temp</span> '+(c.temp_chip||'?')+'\u00b0C</div>';html+='<div><span style=\"color:#888\">PDU</span> '+(c.pdu_power||0)+' kW</div>';html+='<div><span style=\"color:#888\">Profile</span> '+(c.current_profile||'\u2014')+'</div></div>';if(c.issue){html+='<div style=\"background:#1a0a0a;border-left:3px solid #e74c3c;padding:6px 10px;margin-bottom:10px;color:#e88;border-radius:2px\">'+c.issue+'</div>';}else{html+='<div style=\"background:#0a1a0a;border-left:3px solid #2ecc71;padding:6px 10px;margin-bottom:10px;color:#8e8;border-radius:2px\">No active issues</div>';}if(d.dead_boards){html+='<div style=\"background:#1a0a0a;border-left:3px solid #c0392b;padding:6px 10px;margin-bottom:10px;color:#e88;border-radius:2px\">Dead boards: '+d.dead_boards.board_indices+' | Ticket: '+(d.dead_boards.ticket_created||'pending')+'</div>';}if(d.history&&d.history.length){html+='<table style=\"width:100%;border-collapse:collapse\"><thead><tr style=\"color:#666;border-bottom:1px solid #222\"><th style=\"padding:4px 8px;text-align:left\">Time</th><th style=\"padding:4px 8px;text-align:left\">Decision</th><th style=\"padding:4px 8px;text-align:left\">Action</th><th style=\"padding:4px 8px;text-align:left\">By</th><th style=\"padding:4px 8px;text-align:left\">Problem</th></tr></thead><tbody>';d.history.forEach(function(h){var dc=h.decision==='APPROVED'?'#2ecc71':h.decision==='DENIED'?'#e74c3c':'#f39c12';var ts=(h.timestamp||'').substring(0,16).replace('T',' ');html+='<tr style=\"border-bottom:1px solid #1a1a1a\"><td style=\"padding:4px 8px;color:#888\">'+ts+'</td><td style=\"padding:4px 8px;color:'+dc+';font-weight:600\">'+h.decision+'</td><td style=\"padding:4px 8px\">'+h.action_taken+'</td><td style=\"padding:4px 8px;color:#888\">'+h.approved_by+'</td><td style=\"padding:4px 8px;color:#aaa;font-size:11px\">'+h.problem+'</td></tr>';});html+='</tbody></table>';}else{html+='<div style=\"color:#666;padding:8px\">No actions taken yet</div>';}el.innerHTML=html;}).catch(function(e){document.getElementById('mg-status').innerHTML='<span style=\"color:#e74c3c\">Error loading status: '+e.message+'</span>';});})();</script>",
        "mode": "html"
      },
      "title": "Status & Action History \u2014 $miner",
