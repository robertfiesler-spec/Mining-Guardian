[Unit]
Description=Mining Guardian Dashboard API
After=network.target mining-guardian.service

[Service]
EnvironmentFile=/root/Mining-Guardian/.env
Type=simple
User=root
WorkingDirectory=/root/Mining-Guardian
ExecStart=/root/Mining-Guardian/venv/bin/python api/dashboard_api.py
Restart=always
RestartSec=10
Environment=PATH=/root/Mining-Guardian/venv/bin:/usr/local/bin:/usr/bin

[Install]
WantedBy=multi-user.target
