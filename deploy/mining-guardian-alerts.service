[Unit]
Description=Mining Guardian AMS Alert Listener
After=network.target mining-guardian.service approval-api.service
Wants=approval-api.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/Mining-Guardian
EnvironmentFile=/root/Mining-Guardian/.env
ExecStart=/root/Mining-Guardian/venv/bin/python /root/Mining-Guardian/api/ams_alert_listener.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mg-alerts

# Resource limits — this is a small service, no need for much
MemoryMax=256M
TasksMax=20

[Install]
WantedBy=multi-user.target
