[Unit]
Description=Mining Guardian Approval API
After=network.target mining-guardian.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/Mining-Gaurdian
ExecStart=/root/Mining-Gaurdian/venv/bin/python api/approval_api.py
Restart=always
RestartSec=10
Environment=PATH=/root/Mining-Gaurdian/venv/bin:/usr/local/bin:/usr/bin

[Install]
WantedBy=multi-user.target
